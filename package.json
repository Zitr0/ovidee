{
  "name": "ovidee",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @ovidee/server --filter @ovidee/web dev",
    "setup:doctor": "node scripts/doctor.mjs",
    "setup:models": "uv run --directory engine python scripts/download_models.py",
    "setup:browser": "pnpm exec remotion browser ensure"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.0",
    "hyperframes": "0.7.37",
    "remotion": "^4.0.0"
  }
}
